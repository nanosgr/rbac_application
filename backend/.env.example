# Configuración de la aplicación
PROJECT_NAME="RBAC Application"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Configuración de seguridad (REQUERIDO: generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY="your-super-secret-key-change-this-in-production-make-it-very-long-and-random"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Configuración de base de datos PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_USER=rbac_user
POSTGRES_PASSWORD=rbac_password
POSTGRES_DB=rbac_app
POSTGRES_PORT=5432

# URL de base de datos completa (opcional, se construye automáticamente si no se especifica)
# DATABASE_URL=postgresql://rbac_user:rbac_password@localhost:5432/rbac_app

# Configuración CORS - agregar las URLs del frontend
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:5173"]
